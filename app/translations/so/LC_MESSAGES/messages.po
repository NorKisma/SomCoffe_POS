#: app/blueprints/auth/routes.py:24
msgid "You have logged in successfully!"
msgstr "Si guul leh ayaad u gashay nidaamka!"

#: app/blueprints/auth/routes.py:27
msgid "Invalid username or password!"
msgstr "Magaca ama furaha sirta ah waa khalad!"

#: app/blueprints/auth/routes.py:35
msgid "You have logged out successfully!"
msgstr "Si guul leh ayaad uga baxday nidaamka!"

#: app/blueprints/auth/routes.py:52
msgid "Your OTP Code"
msgstr "Furahaaga Sirta ah (OTP Code)"

#: app/blueprints/auth/routes.py:55
#, python-format
msgid "Your password reset code is: %(otp)s. Valid for 10 minutes."
msgstr "Koodhkaaga bedelaadda furaha waa: %(otp)s. Wuxuu dhacayaa 10 daqiiqo gudahood."

#: app/blueprints/auth/routes.py:59
msgid "OTP code has been sent to your email."
msgstr "Koodhka OTP-ga waxaa loo soo diray email-kaaga."

#: app/blueprints/auth/routes.py:62
#, python-format
msgid "Error sending email: %(error)s"
msgstr "Cillad ayaa dhacday markii la dirayay email-ka: %(error)s"

#: app/blueprints/auth/routes.py:64
#, python-format
msgid "Email (%(email)s) not found in the system!"
msgstr "Email-ka (%(email)s) nidaamka kuma jiro!"

#: app/blueprints/auth/routes.py:82
msgid "Invalid or expired OTP code!"
msgstr "Koodhka OTP-ga waa khalad ama wuu dhacay!"

#: app/blueprints/auth/routes.py:96
msgid "Passwords do not match!"
msgstr "Furayaashu isuma mid aha!"

#: app/blueprints/auth/routes.py:111
msgid "Your password has been reset successfully!"
msgstr "Furahaaga si guul leh ayaa loo bedelay!"

#: app/blueprints/auth/routes.py:121
msgid "Incorrect PIN!"
msgstr "PIN-ka waa khalad!"

