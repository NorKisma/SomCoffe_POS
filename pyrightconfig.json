{
    "include": [
        "."
    ],
    "exclude": [
        "**/node_modules",
        "**/__pycache__",
        "venv"
    ],
    "extraPaths": [
        "."
    ],
    "executionEnvironments": [
        {
            "root": ".",
            "pythonVersion": "3.10",
            "pythonPath": "venv/Scripts/python.exe"
        }
    ],
    "typeCheckingMode": "basic",
    "reportMissingImports": true
}