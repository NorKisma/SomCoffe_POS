# SomCoffe POS - Environment Variables

# APP CONFIGURATION
SECRET_KEY=somcoffe-pos-super-secret-key-2026
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1

# DATABASE CONFIGURATION
# DB_MODE can be 'offline' (uses local SQLite) or 'online' (uses remote database like MySQL)
DB_MODE=online

# MySQL Configuration
# Format: mysql+pymysql://username:password@server:port/db_name?charset=utf8mb4
ONLINE_DATABASE_URL=mysql+pymysql://root:@localhost:3307/somcoffe?charset=utf8mb4

# EMAIL / SMTP CONFIGURATION
# Setup used for resetting passwords, sending reports, etc.
MAIL_USERNAME=your_gmail@gmail.com
# Use an App Password if using Gmail, not your normal password!
MAIL_PASSWORD=your_app_password_here
